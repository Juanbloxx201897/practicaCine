@model SistemaCine.Models.Cine

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-body p-5">

                    <h1 class="mb-4 fw-bold">
                        🎬 Registrar Película
                    </h1>

                    <form asp-action="Crear" method="post">

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                ID
                            </label>

                            <input asp-for="Id"
                                   class="form-control form-control-lg" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Película
                            </label>

                            <input asp-for="Pelicula"
                                   class="form-control form-control-lg" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Sala
                            </label>

                            <input asp-for="Sala"
                                   class="form-control form-control-lg" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Fecha de Función
                            </label>

                            <input asp-for="FechaFuncion"
                                   type="datetime-local"
                                   class="form-control form-control-lg" />
                        </div>

                        <div class="form-check mb-4">

                            <input asp-for="Disponible"
                                   class="form-check-input" />

                            <label class="form-check-label">
                                Disponible
                            </label>

                        </div>

                        <div class="d-grid">

                            <button type="submit"
                                    class="btn btn-success btn-lg">

                                Guardar Película

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>